# company-os — Credential Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in the values you need.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# Run `./credentials/check.sh` to see what's missing and what it unlocks.
#
# Tiers:
#   CORE      — unlocks the agent entirely (agent won't work without it)
#   RECOMMENDED — major workflow improvement (agent works, but degraded without it)
#   OPTIONAL  — nice to have, specific integrations only
# ─────────────────────────────────────────────────────────────────────────────


# ── GitHub (release-engineer) ─────────────────────────────────────────────────
# Tier: RECOMMENDED — /ship and /land-and-deploy work best with this set.
# Get it: github.com/settings/tokens → New token (classic)
# Scopes: repo, workflow
GH_TOKEN=


# ── X / Twitter (research-analyst, solo-founder) ─────────────────────────────
# Tier: RECOMMENDED — /x-research and /last30days-nux are partially blind without it.
# Pick ONE method:

# Method A (recommended): xAI API — no browser, no cookie expiry, pay-per-use
# Get it: api.x.ai → Create key
XAI_API_KEY=

# Method B (free): reads your logged-in x.com cookies from your local browser.
# Set to "auto" to enable. Chrome on macOS will prompt for Keychain access.
# FROM_BROWSER=auto

# Method C (manual): paste cookies from browser devtools
# x.com → F12 → Application → Cookies → copy auth_token and ct0
# X_AUTH_TOKEN=
# X_CT0=


# ── Web Search (research-analyst, solo-founder) ───────────────────────────────
# Tier: OPTIONAL — fallback when Reddit/X don't cover a topic.

# Brave Search — 2,000 free queries/month
# Get it: brave.com/search/api
BRAVE_API_KEY=

# Exa — semantic web search, 1,000 free queries/month
# Get it: exa.ai → API keys
EXA_API_KEY=

# OpenRouter — routes to Perplexity Sonar for deep research with citations
# Get it: openrouter.ai → Create key
OPENROUTER_API_KEY=


# ── Social Research — TikTok & Instagram (research-analyst, solo-founder) ─────
# Tier: OPTIONAL — adds TikTok, Instagram, and Reddit backup to /last30days-nux.
# 10,000 free API calls, no credit card required.
# Get it: scrapecreators.com
SCRAPECREATORS_API_KEY=


# ── Bluesky (research-analyst) ────────────────────────────────────────────────
# Tier: OPTIONAL — adds Bluesky to /last30days-nux research.
# Get it: bsky.app/settings/app-passwords → Create app password
BSKY_HANDLE=
BSKY_APP_PASSWORD=


# ── Newsletter (solo-founder → /content-machine) ─────────────────────────────
# Tier: OPTIONAL — enables automated newsletter drafting and scheduling.
# Pick the platform you use:

# Beehiiv (recommended for build-in-public, newsletters)
# Get it: app.beehiiv.com → Settings → API
BEEHIIV_API_KEY=

# ConvertKit (recommended for lead gen, email sequences)
# Get it: app.convertkit.com → Settings → Advanced → API Secret
CONVERTKIT_API_KEY=

# Substack — no API; manual posting only. No key needed.


# ── Cap Table (solo-founder → /cap-table) ─────────────────────────────────────
# Tier: OPTIONAL — enables live cap table sync and dilution modeling.

# Carta — most common for VC-backed startups
# Get it: carta.com → Settings → Integrations → API
CARTA_API_KEY=

# Pulley — recommended for early-stage, simpler setup
# Get it: pulley.com → Settings → API access
PULLEY_API_KEY=


# ── Product Demos (solo-founder → /demo-script) ───────────────────────────────
# Tier: OPTIONAL — enables programmatic demo uploads and sharing links.

# Loom — async video demos
# Get it: loom.com → Settings → Integrations → API
LOOM_API_KEY=


# ── Stripe (solo-founder → /legal-basics, /runway) ───────────────────────────
# Tier: OPTIONAL — enables live MRR/revenue data in /runway calculations.
# Get it: dashboard.stripe.com → Developers → API keys → Restricted key
# Scope: Read-only on charges, subscriptions, customers
STRIPE_SECRET_KEY=


# ── Deployment (release-engineer → /land-and-deploy) ─────────────────────────
# Tier: CORE for your platform — set the one you use.
# Run /setup-deploy in Claude Code to configure this automatically.

# Vercel
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Fly.io
FLY_API_TOKEN=

# Render
RENDER_API_KEY=
RENDER_SERVICE_ID=
